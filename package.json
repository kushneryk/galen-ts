{
  "name": "galen-ts",
  "version": "0.1.0",
  "description": "Layout testing framework for web applications, powered by Playwright",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": ["layout", "testing", "playwright", "galen", "responsive", "visual-testing"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kushneryk/galen-ts.git"
  },
  "homepage": "https://github.com/kushneryk/galen-ts",
  "bugs": {
    "url": "https://github.com/kushneryk/galen-ts/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "playwright": "^1.50.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
